  "certifications": [
    {
      "name": "Fairtrade International",
      "description": "Global certification ensuring producers receive a Fairtrade Minimum Price and Premium for community investment. Administered by Fairtrade International (FLO) and audited by FLOCERT."
    },
    {
      "name": "Fair Trade USA",
      "description": "US-based certification (split from Fairtrade International in 2011) covering smallholder cooperatives and estate workers under its Trade Standard."
    },
    {
      "name": "USDA Organic",
      "description": "US Department of Agriculture certification prohibiting synthetic pesticides, fertilizers, and GMOs for at least three years on the production land."
    },
    {
      "name": "EU Organic",
      "description": "European Union organic farming label governed by Regulation (EU) 2018/848; requires audited compliance with EU organic production rules."
    },
    {
      "name": "JAS Organic",
      "description": "Japanese Agricultural Standard for organic products; required for coffee marketed as 'organic' in Japan."
    },
    {
      "name": "Rainforest Alliance",
      "description": "Sustainable agriculture certification covering biodiversity, worker welfare, and climate-smart practices. Merged with UTZ in 2018 under a unified 2020 standard."
    },
    {
      "name": "Smithsonian Bird Friendly",
      "description": "Certification by the Smithsonian Migratory Bird Center for shade-grown, organic coffee that preserves bird habitat. The most stringent shade-coffee standard."
    },
    {
      "name": "4C Certified",
      "description": "Baseline sustainability standard administered by the 4C Services GmbH (formerly Common Code for the Coffee Community); covers social, economic, and environmental criteria."
    },
    {
      "name": "C.A.F.E. Practices",
      "description": "Starbucks Coffee and Farmer Equity Practices — a buyer-specific sourcing standard verified by SCS Global Services covering product quality, economic accountability, social responsibility, and environmental leadership."
    },
    {
      "name": "Demeter Biodynamic",
      "description": "International certification for biodynamic agriculture, going beyond organic to require closed-loop farm ecosystems aligned with Rudolf Steiner's principles."
    }
  ],
