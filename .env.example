# Database (read-only content store)
DUCKDB_PATH=./data/coffee_atlas.duckdb

# User data store (Postgres). Provider-agnostic — Supabase or Neon both work.
# Leave empty to run content-only (auth/account features disabled). On Neon,
# prefer the "-pooler" host. Example:
#   postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Local dev: point at any local Postgres (e.g. Postgres.app) after creating a
# role + database for it:
#   CREATE ROLE coffee LOGIN PASSWORD 'coffee';
#   CREATE DATABASE coffee_atlas_users OWNER coffee;
#   postgresql://coffee:coffee@localhost:5432/coffee_atlas_users
DATABASE_URL=

# Auth (custom JWT in an httpOnly cookie). REQUIRED when DATABASE_URL is set:
# the API refuses to start unless this is a strong value (>= 32 chars), since an
# empty/weak secret lets anyone forge session tokens.
# Generate one: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_TTL_MINUTES=10080      # 7 days
# COOKIE_NAME=ca_session
COOKIE_SECURE=true                    # set false for local http dev
# COOKIE_SAMESITE=lax

# APIs. Leave GEMINI_API_KEY empty (not a placeholder — any non-empty value
# is treated as a real key) to have /search/semantic fall back to text search.
GEMINI_API_KEY=

# Server. BACKEND_PORT is read by `just dev-backend`; if you change it, point
# the frontend proxy at the new port too (BACKEND_URL is read by
# frontend/next.config.js at BUILD time, default http://localhost:8000).
BACKEND_PORT=8000
# BACKEND_URL=http://localhost:8000

# Feature flags
ENABLE_EMBEDDINGS=true
