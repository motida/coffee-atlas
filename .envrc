# Load environment variables from .env (GEMINI_API_KEY, etc.)
dotenv_if_exists

# Activate the project's Python virtualenv so `python`, `pytest`, etc. resolve to it
if [[ -f .venv/bin/activate ]]; then
    source .venv/bin/activate
fi

# Make `python -m backend.xxx` work from any subdirectory
export PYTHONPATH="${PWD}:${PYTHONPATH:-}"
